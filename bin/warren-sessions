#!/usr/bin/env python3
"""List Claude Code sessions across ALL projects, most-recent first.

Reads ~/.claude/projects/*/*.jsonl directly (rather than relying on
`claude --resume`'s cwd-scoped picker, whose behavior could change). Emits one
session per line as TSV:

    <sessionId>\t<mtime_epoch>\t<cwd>\t<title>

The session id is the file stem; cwd and title (aiTitle, falling back to the
first user message) are read from the records. Lines are pre-filtered by a
cheap substring test so large assistant records are not JSON-parsed.
"""
import os, sys, json, glob

root = os.path.expanduser("~/.claude/projects")
rows = []

for path in glob.glob(os.path.join(root, "*", "*.jsonl")):
    sid = os.path.splitext(os.path.basename(path))[0]
    try:
        mtime = os.path.getmtime(path)
    except OSError:
        continue
    cwd = ""
    title = ""
    first_user = ""
    try:
        with open(path, "r", errors="replace") as fh:
            for ln in fh:
                want_title = '"aiTitle"' in ln
                want_cwd = (not cwd) and ('"cwd"' in ln)
                want_user = (not first_user and not title) and ('"type":"user"' in ln or '"type": "user"' in ln)
                if not (want_title or want_cwd or want_user):
                    continue
                try:
                    d = json.loads(ln)
                except Exception:
                    continue
                if want_cwd and d.get("cwd"):
                    cwd = d["cwd"]
                if want_title and d.get("aiTitle"):
                    title = d["aiTitle"]
                if want_user and d.get("type") == "user" and not first_user:
                    m = d.get("message", {})
                    c = m.get("content") if isinstance(m, dict) else None
                    if isinstance(c, str):
                        first_user = c
                    elif isinstance(c, list):
                        for part in c:
                            if isinstance(part, dict) and part.get("type") == "text":
                                first_user = part.get("text", "")
                                break
    except OSError:
        continue

    label = title or first_user or "(untitled)"
    label = " ".join(label.split())[:80]
    rows.append((mtime, sid, cwd or "?", label))

rows.sort(reverse=True)
out = []
for mtime, sid, cwd, label in rows:
    out.append(f"{sid}\t{int(mtime)}\t{cwd}\t{label}")
sys.stdout.write("\n".join(out) + ("\n" if out else ""))
