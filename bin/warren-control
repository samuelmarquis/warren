#!/bin/zsh
# warren-control - the create form ("+ new agent" tab) and the edit form.
#
# Default (no args): a form to create an agent. On Enter it shells out to
# `warren new`, which creates the agent's abduco session and injects a live
# window into this dvtm (focus then jumps to the new agent). Modes:
#   new       a fresh Claude session in the chosen Root dir
#   resume    pick ANY past session (across all projects, from `warren-sessions`)
#   continue  continue the most recent conversation in the chosen Root dir
#
# `--edit <session> <name> <color>`: a trimmed form (Name + Color only) for a
# running agent, opened by `e` in NORMAL mode. On Enter it writes `rename` /
# `recolor` to $DVTM_CMD_FIFO so dvtm relabels/recolors the live tab in place.
#
# In both forms hjkl mirror the arrow keys on chooser fields (Mode/Color and the
# session list); on the text fields (Name/Root dir) they type literally.
emulate -L zsh
setopt no_nomatch
zmodload zsh/datetime 2>/dev/null

typeset -a mname mhint
mname=(new resume continue)
mhint=("a fresh Claude session in the Root dir below" \
       "pick any past session from any project, then resume it" \
       "continue the most recent conversation in the Root dir below")

mode=0
title=""
rootdir="$HOME"
color=""             # tab color: an xterm-256 index or a #hex code ("" = none)
fi=0                 # index (0-based) into the current field list

editing=0
EDIT_SESSION=""
if [[ $1 == --edit ]]; then
	editing=1; EDIT_SESSION=$2; title=$3; color=${4:-0}
	[[ $color == 0 ]] && color=""     # show "none" rather than the index 0
fi

typeset -a fields
typeset -a ssid smtime scwd stitle
ssel=1; soff=0; sloaded=0
msg=""

cleanup() { stty sane 2>/dev/null; print -rn -- $'\e[?25h'; }
trap cleanup EXIT INT TERM
stty -icanon -echo -isig min 1 time 0 2>/dev/null

term_size() {
	local sz; sz=$(stty size 2>/dev/null)
	ROWS=${sz%% *}; COLS=${sz##* }
	[[ $ROWS == <-> ]] || ROWS=24
	[[ $COLS == <-> ]] || COLS=80
}

compute_fields() {
	if (( editing )); then
		fields=(title color)
	else
		case $mode in
			0) fields=(mode title rootdir color) ;;
			1) fields=(mode color) ;;
			2) fields=(mode rootdir color) ;;
		esac
	fi
	(( fi >= ${#fields} )) && fi=0
}

is_text() { [[ ${fields[fi+1]} == title || ${fields[fi+1]} == rootdir || ${fields[fi+1]} == color ]]; }

load_sessions() {
	ssid=(); smtime=(); scwd=(); stitle=()
	local id mt cwd ttl
	while IFS=$'\t' read -r id mt cwd ttl; do
		[[ -n $id ]] || continue
		ssid+=("$id"); smtime+=("$mt"); scwd+=("$cwd"); stitle+=("$ttl")
	done < <(warren-sessions 2>/dev/null)
	ssel=1; soff=0; sloaded=1
}

reltime() {
	local d=$(( ${EPOCHSECONDS:-$1} - $1 ))
	if   (( d < 60 ));    then printf '%4s' "now"
	elif (( d < 3600 ));  then printf '%3dm' $(( d/60 ))
	elif (( d < 86400 )); then printf '%3dh' $(( d/3600 ))
	else                       printf '%3dd' $(( d/86400 )); fi
}
abbr() { print -rn -- "${1/#$HOME/~}"; }

lead() { # field-type label  -> bold "> " if focused
	if [[ ${fields[fi+1]} == $1 ]]; then print -rn -- $'\e[1m'"  > $2 "$'\e[0m'
	else                                  print -rn -- "    $2 "; fi
}

# a live swatch for the current color value. Hex codes are emitted as truecolor
# (dvtm quantizes them to the nearest 256 color, exactly as it will store them);
# a bare decimal is shown as that 256-color index.
color_swatch() {
	local c=$color
	[[ -z $c ]] && { print -rn -- $'\e[2m'"(none)"$'\e[0m'; return; }
	[[ $c == \#* ]] && c=${c#\#}
	if [[ $c == <-> ]] && (( c >= 0 && c <= 255 )); then
		(( c == 0 )) && { print -rn -- $'\e[2m'"(none)"$'\e[0m'; return; }
		print -rn -- $'\e[48;5;'"${c}m      "$'\e[0m'; return
	fi
	if [[ $c =~ '^[0-9a-fA-F]{3}$' || $c =~ '^[0-9a-fA-F]{6}$' ]]; then
		local r g b
		if (( ${#c} == 3 )); then
			r=$(( 16#${c[1]}${c[1]} )); g=$(( 16#${c[2]}${c[2]} )); b=$(( 16#${c[3]}${c[3]} ))
		else
			r=$(( 16#${c[1,2]} )); g=$(( 16#${c[3,4]} )); b=$(( 16#${c[5,6]} ))
		fi
		print -rn -- $'\e[48;2;'"${r};${g};${b}m      "$'\e[0m'; return
	fi
	print -rn -- $'\e[2m'"(type a #hex or 0-255)"$'\e[0m'
}

render_color() {
	local cur=""
	[[ ${fields[fi+1]} == color ]] && cur=$'\e[7m \e[0m'
	lead color "Color   "
	print -rn -- "${color}${cur}  "
	color_swatch
	print -rn -- $'\r\n\r\n'
}

render() {
	local nl=$'\r\n' i sw cur
	term_size
	print -rn -- $'\e[2J\e[H\e[?25l'

	if (( editing )); then
		print -rn -- $'\e[1m'"  ~  edit agent"$'\e[0m'"$nl$nl"
		[[ ${fields[fi+1]} == title ]] && cur=$'\e[7m \e[0m' || cur=""
		lead title "Name    "; print -rn -- "${title}${cur}$nl$nl"
		render_color
		print -rn -- $'\e[2m'"  rename / recolor this running agent"$'\e[0m'"$nl"
		[[ -n $msg ]] && print -rn -- "  $msg$nl"
		print -rn -- $'\e[2m'"  Tab/↑↓ move · Color: type #hex or 0-255 · Enter: save · Esc: cancel"$'\e[0m'"$nl"
		return
	fi

	print -rn -- $'\e[1m'"  +  new claude agent"$'\e[0m'"$nl$nl"
	lead mode "Mode    "
	for i in {0..2}; do
		sw=" ${mname[i+1]} "
		if (( i == mode )); then print -rn -- $'\e[7m'"$sw"$'\e[0m'; else print -rn -- "$sw"; fi
	done
	print -rn -- "$nl$nl"

	if (( mode == 1 )); then
		local n=${#ssid} vis=$(( ROWS - 9 ))
		(( vis < 3 )) && vis=3; (( vis > 18 )) && vis=18
		(( ssel < 1 )) && ssel=1; (( ssel > n )) && ssel=n
		(( ssel <= soff )) && soff=$(( ssel - 1 ))
		(( ssel > soff + vis )) && soff=$(( ssel - vis ))
		(( soff < 0 )) && soff=0
		if (( n == 0 )); then
			print -rn -- $'\e[2m'"  (no past sessions found)"$'\e[0m'"$nl"
		else
			print -rn -- $'\e[2m'"  Pick a session  (${ssel}/${n}):"$'\e[0m'"$nl"
			local cwdw=26 tw idx end a line
			tw=$(( COLS - 4 - 4 - cwdw - 2 - 1 )); (( tw < 8 )) && tw=8
			end=$(( soff + vis )); (( end > n )) && end=n
			for (( idx = soff + 1; idx <= end; idx++ )); do
				a=$(abbr "${scwd[idx]}")
				line=$(printf '%s %-*.*s  %-.*s' "$(reltime ${smtime[idx]})" $cwdw $cwdw "$a" $tw "${stitle[idx]}")
				if (( idx == ssel )); then print -rn -- $'\e[7m'"  > ${line}"$'\e[0m'$'\r\n'
				else                        print -rn -- "    ${line}$nl"; fi
			done
			(( end < n )) && print -rn -- $'\e[2m'"    … $(( n - end )) more"$'\e[0m'"$nl"
		fi
		print -rn -- "$nl"
	elif (( mode == 2 )); then
		[[ ${fields[fi+1]} == rootdir ]] && cur=$'\e[7m \e[0m' || cur=""
		lead rootdir "Root dir"; print -rn -- "${rootdir}${cur}$nl$nl"
	else
		[[ ${fields[fi+1]} == title ]] && cur=$'\e[7m \e[0m' || cur=""
		lead title "Title   "; print -rn -- "${title}${cur}$nl"
		[[ ${fields[fi+1]} == rootdir ]] && cur=$'\e[7m \e[0m' || cur=""
		lead rootdir "Root dir"; print -rn -- "${rootdir}${cur}$nl$nl"
	fi

	render_color
	print -rn -- $'\e[2m'"  ${mhint[mode+1]}"$'\e[0m'"$nl"
	[[ -n $msg ]] && print -rn -- "  $msg$nl"
	if (( mode == 1 )); then
		print -rn -- $'\e[2m'"  jk pick · Tab move · Color: type #hex or 0-255 · Enter: resume · Esc: clear"$'\e[0m'"$nl"
	else
		print -rn -- $'\e[2m'"  Tab/↑↓ move · hl change mode · Color: #hex or 0-255 · Enter: create · Esc: clear"$'\e[0m'"$nl"
	fi
}

append() {
	case $1 in '"'|'\') return ;; esac           # keep names FIFO/shell-quoting-safe
	[[ $1 == [[:print:]] ]] || return
	case ${fields[fi+1]} in title) title+=$1 ;; rootdir) rootdir+=$1 ;; color) color+=$1 ;; esac
}
backspace() { case ${fields[fi+1]} in title) title=${title%?} ;; rootdir) rootdir=${rootdir%?} ;; color) color=${color%?} ;; esac; }
reset_form() { mode=0; title=""; rootdir="$HOME"; color=""; fi=0; msg=""; compute_fields; }

set_mode() { mode=$(( ($1 + 3) % 3 )); fi=0; compute_fields; (( mode == 1 )) && load_sessions; }

bump() { case ${fields[fi+1]} in mode) set_mode $(( mode + $1 )) ;; esac; }
nav()  { fi=$(( (fi + $1 + ${#fields}) % ${#fields} )); }

do_up()    { if (( mode == 1 && !editing )); then (( ssel > 1 )) && (( ssel-- )); else nav -1; fi; }
do_down()  { if (( mode == 1 && !editing )); then (( ssel < ${#ssid} )) && (( ssel++ )); else nav 1; fi; }
do_left()  { bump -1; }
do_right() { bump 1; }

submit() {
	local name dir m sid
	local col=${color:-0}
	if (( editing )); then
		[[ -n $title ]] || { msg="enter a name"; return; }
		printf 'rename "%s" "%s"\nrecolor "%s" "%s"\n' "$EDIT_SESSION" "$title" "$EDIT_SESSION" "$col" > "$DVTM_CMD_FIFO"
		exit 0
	fi
	case $mode in
		0)  [[ -n $title ]] || { msg="enter a title first"; return; }
		    name=$title; dir=$rootdir; m=new ;;
		2)  dir=$rootdir; name=${dir:t}; [[ -z $name || $name == / ]] && name=continue; m=continue ;;
		1)  if (( ${#ssid} == 0 )); then msg="no sessions to resume"; return; fi
		    dir=${scwd[ssel]}; [[ $dir == "?" || -z $dir ]] && dir=$HOME
		    name=${dir:t}; [[ -z $name || $name == / ]] && name=resumed
		    m=resume; sid=${ssid[ssel]} ;;
	esac
	msg="creating '${name}' (${m})..."
	render
	if [[ $m == resume ]]; then
		warren new "$name" "$dir" "$col" resume "$sid" >/dev/null 2>&1
	else
		warren new "$name" "$dir" "$col" "$m" >/dev/null 2>&1
	fi
	reset_form
}

compute_fields
while true; do
	render
	IFS= read -k1 key || break
	case $key in
		$'\t')            nav 1 ;;
		$'\n'|$'\r')      submit ;;
		$'\x7f'|$'\x08')  backspace ;;
		$'\e')
			if read -t 0.06 -k1 a 2>/dev/null && [[ $a == "[" || $a == "O" ]]; then
				read -t 0.06 -k1 b 2>/dev/null
				case $b in
					A) do_up ;;  B) do_down ;;  C) do_right ;;  D) do_left ;;  Z) nav -1 ;;
				esac
			elif (( editing )); then
				exit 0                       # bare Esc cancels the edit
			else
				reset_form
			fi
			;;
		' ')  case ${fields[fi+1]} in mode|color) bump 1 ;; *) append " " ;; esac ;;
		h|j|k|l)
			if is_text; then append "$key"
			else case $key in h) do_left ;; j) do_down ;; k) do_up ;; l) do_right ;; esac
			fi
			;;
		*)    append "$key" ;;
	esac
done
